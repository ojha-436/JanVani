rules_version = '2';

// ------------------------------------------------------------------
// JanVaani Firestore rules — server-mediated by design.
//
// All reads and writes go through the Next.js API routes using the
// Firebase Admin SDK (which bypasses these rules). The browser never
// touches Firestore directly, so the client surface is denied entirely.
// This keeps citizen PII and raw submissions off the client and makes
// the server the single, validated write path (ARCHITECTURE.md §9).
// ------------------------------------------------------------------
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
