# ------------------------------------------------------------------
# JanVaani environment variables
# Copy this file to `.env.local` and fill in your values.
# NEVER commit .env.local — it is gitignored.
# ------------------------------------------------------------------

# --- Backend API (FastAPI, local for now) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Firebase (client SDK — safe to expose, protected by Firebase rules) ---
# Get these from Firebase Console → Project settings → Your apps → Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Server-side Google Cloud (NEVER prefixed with NEXT_PUBLIC) ---
# On Cloud Run these services authenticate via the attached service
# account (Application Default Credentials) — no key files needed.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI — Gemini for photo analysis, extraction, clustering & rationale.
# Flash-Lite for high-volume extraction; Flash/Pro for the ranking rationale.
GEMINI_MODEL=gemini-2.5-flash-lite

# BigQuery — analytics warehouse that runs the ranking engine.
BIGQUERY_DATASET=janvaani

# Cloud Storage bucket for citizen voice/photo uploads.
UPLOADS_BUCKET=janvaani-uploads

# Speech-to-Text recognizer region + Pub/Sub topic for async processing.
SPEECH_TO_TEXT_LOCATION=us-central1
PUBSUB_TOPIC=raw-submissions

# Google Maps Platform (geocoding + hotspot map). The JS key is public but
# MUST be restricted by HTTP referrer + API in the Cloud console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Firebase App Check (Firebase console -> App Check -> register web app ->
# reCAPTCHA v3). Leaving this blank just means App Check tokens aren't sent —
# harmless unless the backend's ENFORCE_APP_CHECK is also turned on.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Backend-only: when "true", requests to complaint submission and gov-data
# endpoints must carry a valid App Check token. Keep "false" until a real
# reCAPTCHA site key is registered, or all requests will be rejected.
ENFORCE_APP_CHECK=false
