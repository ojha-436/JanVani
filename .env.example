# ------------------------------------------------------------------
# JanVaani environment variables
# Copy this file to `.env.local` and fill in your values.
# NEVER commit .env.local — it is gitignored.
# ------------------------------------------------------------------

# --- Firebase (client SDK — safe to expose, protected by Firebase rules) ---
# Get these from Firebase Console → Project settings → Your apps → Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Google Maps (optional) ---
# If set, the MP dashboard's demand map renders real Google Maps tiles.
# Leave blank to use the built-in SVG map (no key, still fully interactive).
# Create a browser key (see docs/DEPLOY.md §6) and restrict it by HTTP referrer.
# This is a build-time value — it must be present when `next build` runs.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Server-side Google Cloud (NEVER prefixed with NEXT_PUBLIC) ---
# Setting GOOGLE_CLOUD_PROJECT switches the backend from demo mode to live
# (Firestore + Storage + Gemini + Speech-to-Text). Leave blank to run the UI
# with no cloud calls. On Cloud Run credentials come from the attached service
# account via Application Default Credentials — no key files in the container.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI — Gemini (extraction, photo analysis, "why this rank" rationale).
# Use a model your project/region can access (list: gcloud ai model-garden ...).
VERTEX_GEMINI_MODEL=gemini-2.5-flash

# Cloud Storage bucket for citizen voice/photo uploads.
UPLOADS_BUCKET=janvaani-uploads

# Salt for the non-reversible citizen key (dedup / anti-spam). Use a long random
# string in production; never commit the real value.
SUBMISSION_SALT=change-me-in-production

# Optional: base64-encoded service-account JSON for local dev without
# `gcloud auth application-default login`. Leave unset on Cloud Run.
# FIREBASE_SERVICE_ACCOUNT_B64=
